# The Code Munk - Environment Configuration
# Copy this file to ".env" and fill in your values.
# On Hostinger: edit this in the File Manager after uploading, then rename to .env

APP_NAME="The Code Munk"
APP_ENV=production
APP_DEBUG=false
# Leave EMPTY if the site is served from the domain root (public_html).
# Set to e.g. "/tcm" only if you installed it inside a sub-folder.
APP_BASE_PATH=
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Kolkata
# Generate a long random string (used to sign sessions/CSRF).
APP_KEY=change-this-to-a-long-random-string

# --- Database (Hostinger: create it in hPanel > Databases > MySQL) ---
# Hostinger DB host is usually "localhost". Names look like u123456789_tcm.
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u000000000_tcm
DB_USERNAME=u000000000_tcm
DB_PASSWORD=your-db-password
DB_CHARSET=utf8mb4

# --- Session ---
SESSION_NAME=tcm_session
SESSION_LIFETIME=7200

# --- Uploads ---
UPLOAD_MAX_SIZE=5242880
